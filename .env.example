# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans git

# Clé d'intégration Notion
# Obtenir sur : https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de ta base de données Notion
# Se trouve dans l'URL de la base : notion.so/{workspace}/{DATABASE_ID}?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
